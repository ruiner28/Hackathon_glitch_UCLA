# Optional. Leave unset for local dev: the browser calls same-origin /api/* and Next.js proxies to FastAPI.
# Set to a non-local URL only when the API is hosted elsewhere (then no proxy; CORS must allow the web origin).
# NEXT_PUBLIC_API_URL=https://your-api.example.com
#
# Used by next.config rewrites (server-side proxy target). Defaults to http://127.0.0.1:8000
# API_INTERNAL_URL=http://127.0.0.1:8000
#
# Route protection (middleware): /lesson/*, /new, /processing/* require session cookie vc_session.
# Set to false to browse those routes without signing in (local dev).
# NEXT_PUBLIC_REQUIRE_AUTH=false
