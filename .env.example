# Google Cloud
GOOGLE_PROJECT_ID=gen-lang-client-0377256654
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET_NAME=visualcs-assets

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visualcs
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/visualcs

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
# Pre-built assets for homepage showcase topics (see storage/demo_cache/README.md)
DEMO_CACHE_PATH=./storage/demo_cache

# Provider modes (mock | google)
LLM_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
TTS_PROVIDER=mock
MUSIC_PROVIDER=mock

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
