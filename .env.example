# Google Cloud
GOOGLE_PROJECT_ID=gen-lang-client-0377256654
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET_NAME=visualcs-assets

# Gemini / Google GenAI (also accepts env name Gemini_Api_Key)
# Used only when a *_PROVIDER below is "google" (text, images, Veo clips, TTS).
# "Render Final" in the UI muxes with FFmpeg locally — it does not call Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database
# Local dev without Docker: SQLite (API cwd is apps/api — creates visualcs.db there)
DATABASE_URL=sqlite+aiosqlite:///./visualcs.db
# Optional: PostgreSQL instead (e.g. docker compose up postgres -d)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visualcs
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/visualcs

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Storage (paths are relative to apps/api when the API runs)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
# Pre-built assets for homepage showcase topics (see storage/demo_cache/README.md)
DEMO_CACHE_PATH=./storage/demo_cache

# Provider modes (mock | google)
LLM_PROVIDER=mock
IMAGE_PROVIDER=mock
# Real Veo clips: VIDEO_PROVIDER=google + GEMINI_API_KEY. Mock needs ffmpeg on PATH.
VIDEO_PROVIDER=mock
# Generate Animation (lesson page): use disk instead of live Veo when possible.
# - VEO_OFFLINE_USE_DEMO_CACHE=true (default): if lesson topic matches a showcase slug
#   and storage/demo_cache/<slug>/output/lesson.mp4 exists, copy it (no API).
# - VEO_REUSE_EXISTING_OUTPUT=true: if storage/output/<lessonId>/lesson.mp4 already exists, reuse it.
# Set VEO_OFFLINE_USE_DEMO_CACHE=false to force live Veo when you have API access.
# VEO_OFFLINE_USE_DEMO_CACHE=true
# VEO_REUSE_EXISTING_OUTPUT=false
# Optional: Veo model id (default veo-2.0-generate-001)
# VEO_MODEL=veo-2.0-generate-001
TTS_PROVIDER=mock
MUSIC_PROVIDER=mock
# Lyria (Vertex AI): set MUSIC_PROVIDER=google and configure project + ADC
# GOOGLE_CLOUD_LOCATION=us-central1

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Google OAuth (Sign in with Google)
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client:
# - Authorized redirect URI must match exactly (local dev uses Next origin, not :8000):
#   http://localhost:3000/api/auth/callback/google
# The API also accepts: NEXT_PUBLIC_GOOGLE_CLIENT_ID, AUTH_GOOGLE_SECRET (or GOOGLE_CLIENT_SECRET).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
# Session cookie name / TTL (optional)
# SESSION_COOKIE_NAME=vc_session
# SESSION_MAX_AGE_SEC=604800
